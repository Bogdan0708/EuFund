# EU-Funds Production Environment Template
# Copy to .env.production and fill in real values

# ─── Database ────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/fondeu?sslmode=require"

# ─── Redis ───────────────────────────────────
REDIS_URL="redis://HOST:6379"

# ─── Auth ────────────────────────────────────
NEXTAUTH_SECRET="GENERATE_WITH: node -e \"console.log(require('crypto').randomBytes(32).toString('base64url'))\""
NEXTAUTH_URL="https://your-domain.ro"

# ─── AI Providers ────────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
PERPLEXITY_API_KEY=""

# ─── Romanian AI ─────────────────────────────
OPENLLM_RO_API_URL=""
OPENLLM_RO_API_KEY=""

# ─── Email (Gmail App Password) ─────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="FondEU <your-gmail@gmail.com>"

# ─── Runtime ─────────────────────────────────
NODE_ENV="production"
ENABLE_RATE_LIMITING="true"
ENABLE_CSRF_PROTECTION="true"
DEBUG_MODE="false"
BILLING_ENABLED="false"

# ─── GCP ─────────────────────────────────────
GCP_PROJECT_ID="fondeu-platform"
GCP_REGION="europe-west2"
