{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "npx tsx --env-file=.env.production src/lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx --env-file=.env.local src/lib/db/seed.ts",
    "db:seed:prod": "npx tsx --env-file=.env.production src/lib/db/seed.ts",
    "typecheck": "tsc --noEmit",
    "build:production": "NODE_ENV=production npm run build",
    "analyze": "ANALYZE=true npm run build",
    "docker:build": "docker build -f Dockerfile.production -t fondeu-platform .",
    "docker:run": "docker run -p 8080:8080 fondeu-platform",
    "deploy:gcp": "../scripts/deploy.sh",
    "health:check": "curl -f http://localhost:8080/api/health || exit 1",
    "audit:security": "../scripts/security-audit.sh",
    "audit:prod": "npm audit --production",
    "audit:fix": "npm audit fix",
    "audit:fix:prod": "npm audit fix --production",
    "deps:check": "npm outdated",
    "deps:update": "npm update",
    "deps:update:interactive": "npx npm-check-updates -i"
  },
  "dependencies": {
