# AI Providers
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-key
GOOGLE_AI_API_KEY=your-google-ai-key
PERPLEXITY_API_KEY=your-perplexity-key

# AI Gateway
AI_GATEWAY_URL=https://ai-gateway-382299704849.europe-west2.run.app
AI_GATEWAY_API_KEY=your-ai-gateway-key

# Romanian Specialized Models (OpenLLM-Ro / HuggingFace)
OPENLLM_RO_API_KEY=your-huggingface-token
OPENLLM_RO_API_URL=https://api-inference.huggingface.co/models/openllm-ro/rollama3-8b-instruct
ROMANIAN_BERT_ENDPOINT=https://api-inference.huggingface.co/models/dumitrescustefan/bert-base-romanian-cased-v1
HUGGINGFACE_TOKEN=your-huggingface-token

# Vector Store (RAG)
VECTOR_PROVIDER=memory
QDRANT_URL=http://localhost:6333
VECTOR_COLLECTION=eu_legislation

# Application Settings
DATABASE_URL=postgresql://fondeu:CHANGE_ME@localhost:5432/fondeu
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-random-string-here
REDIS_URL=redis://localhost:6379
NODE_ENV=development
SENTRY_DSN=
LOG_LEVEL=info
