# AI Gateway
AI_GATEWAY_URL=https://ai-gateway-j3dqdqxnyq-lm.a.run.app
AI_GATEWAY_API_KEY=your-ai-gateway-key
AI_GATEWAY_TENANT_ID=fondeu-platform
AI_ANALYSIS_MODEL=gpt-4o

# Vector Store (RAG)
VECTOR_PROVIDER=memory
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
VECTOR_COLLECTION=eu_legislation

# Application Settings
DATABASE_URL=postgresql://fondeu:CHANGE_ME@localhost:5432/fondeu
DB_PASS=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-random-string-here
CONSENT_POLICY_VERSION=v1
NEXT_PUBLIC_CONSENT_POLICY_VERSION=v1
REDIS_URL=redis://localhost:6379
NODE_ENV=development
SENTRY_DSN=
SMTP_PASS=
LOG_LEVEL=info
METRICS_AUTH_TOKEN=
HEALTHCHECK_AUTH_TOKEN=
TRIAL_NOTIFICATIONS_AUTH_TOKEN=
ALLOW_DEMO_CALLS=false

# Billing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Storage (GCS optional, local fallback if unset)
UPLOAD_DIR=./uploads
GCS_BUCKET=
GCS_PROJECT_ID=
GCS_KEY_FILENAME=
STORAGE_STRICT_GCS=false
