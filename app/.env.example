# AI Providers (direct SDK — no external gateway)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
PERPLEXITY_API_KEY=
AI_ANALYSIS_MODEL=gpt-4o

# Vector Store (RAG)
VECTOR_PROVIDER=memory
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
VECTOR_COLLECTION=eu_legislation

# Application Settings
DATABASE_URL=postgresql://fondeu:CHANGE_ME@localhost:5432/fondeu
DB_PASS=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-random-string-here

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Email (magic link)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@platformafinantare.eu
CONSENT_POLICY_VERSION=v1
NEXT_PUBLIC_CONSENT_POLICY_VERSION=v1
REDIS_URL=redis://localhost:6379
NODE_ENV=development
SENTRY_DSN=
SMTP_PASS=
LOG_LEVEL=info
METRICS_AUTH_TOKEN=
HEALTHCHECK_AUTH_TOKEN=
TRIAL_NOTIFICATIONS_AUTH_TOKEN=
ALLOW_DEMO_CALLS=false
BILLING_ENABLED=false

# Billing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Storage (GCS optional, local fallback if unset)
UPLOAD_DIR=./uploads
GCS_BUCKET=
GCS_PROJECT_ID=
GCS_KEY_FILENAME=
STORAGE_STRICT_GCS=false
